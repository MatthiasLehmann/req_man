# ReqMan – Docker Umgebungsvariablen
# Kopieren als .env und anpassen:  cp .env.example .env

# ── Sicherheit ────────────────────────────────────────────────────────────────
# JWT-Signierungsschlüssel – UNBEDINGT ändern!
SECRET_KEY=reqman-secret-key-change-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Komma-getrennte Liste erlaubter Origins (Browser-Herkunft)
# Beispiel für eigene Domain: CORS_ORIGINS=https://reqman.example.com
CORS_ORIGINS=http://localhost

# ── KI-Provider ───────────────────────────────────────────────────────────────
# Optionen: ollama | openai | anthropic | openai_compatible
AI_PROVIDER=ollama

# Ollama (lokal, Standard): URL des Ollama-Containers
AI_BASE_URL=http://ollama:11434/v1
AI_MODEL=llama3.2

# OpenAI (optional):
# AI_PROVIDER=openai
# AI_BASE_URL=
# AI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Anthropic (optional):
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
